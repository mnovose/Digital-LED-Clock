#define PIN_SCLK_ONES_MIN  13
#define PIN_OUTCLK_ONES_MIN  14
#define PIN_SER_ONES_MIN  16

#define PIN_SCLK_TENS_MIN  17
#define PIN_OUTCLK_TENS_MIN  21
#define PIN_SER_TENS_MIN  22

#define PIN_SCLK_ONES_HOUR  34
#define PIN_OUTCLK_ONES_HOUR  35
#define PIN_SER_ONES_HOUR  36

#define PIN_SCLK_TENS_HOUR  37
#define PIN_OUTCLK_TENS_HOUR  38
#define PIN_SER_TENS_HOUR  39

#define BUTTON  0




void setup() {
  Serial.begin(115200);  // Start serial communication 

  pinMode(PIN_SCLK_ONES_MIN, OUTPUT);
  pinMode(PIN_OUTCLK_ONES_MIN, OUTPUT);
  pinMode(PIN_SER_ONES_MIN, OUTPUT);

  pinMode(PIN_SCLK_TENS_MIN, OUTPUT);
  pinMode(PIN_OUTCLK_TENS_MIN, OUTPUT);
  pinMode(PIN_SER_TENS_MIN, OUTPUT);

  pinMode(PIN_SCLK_ONES_HOUR, OUTPUT);
  pinMode(PIN_OUTCLK_ONES_HOUR, OUTPUT);
  pinMode(PIN_SER_ONES_HOUR, OUTPUT);

  pinMode(PIN_SCLK_TENS_HOUR, OUTPUT);
  pinMode(PIN_OUTCLK_TENS_HOUR, OUTPUT);
  pinMode(PIN_SER_TENS_HOUR, OUTPUT);

  pinMode(BUTTON, INPUT_PULLUP);
}

//---------------------------------------------------------------------------------------------------------

void loop() { 
  if (digitalRead(BUTTON) == LOW)
  {
    while(true)
    {
      display_blank(PIN_SCLK_TENS_HOUR, PIN_OUTCLK_TENS_HOUR, PIN_SER_TENS_HOUR); //tens place for the hour
      //diplay 1:00
