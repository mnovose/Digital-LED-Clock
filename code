      count_1hour(PIN_SCLK_ONES_MIN, PIN_OUTCLK_ONES_MIN, PIN_SER_ONES_MIN, PIN_SCLK_TENS_MIN, PIN_OUTCLK_TENS_MIN, PIN_SER_TENS_MIN);

      //diplay 2:00
      display_2(PIN_SCLK_ONES_HOUR,PIN_OUTCLK_ONES_HOUR,PIN_SER_ONES_HOUR); //ones place for the hour
      count_1hour(PIN_SCLK_ONES_MIN, PIN_OUTCLK_ONES_MIN, PIN_SER_ONES_MIN, PIN_SCLK_TENS_MIN, PIN_OUTCLK_TENS_MIN, PIN_SER_TENS_MIN);

      //diplay 3:00
      display_3(PIN_SCLK_ONES_HOUR,PIN_OUTCLK_ONES_HOUR,PIN_SER_ONES_HOUR); //ones place for the hour
      count_1hour(PIN_SCLK_ONES_MIN, PIN_OUTCLK_ONES_MIN, PIN_SER_ONES_MIN, PIN_SCLK_TENS_MIN, PIN_OUTCLK_TENS_MIN, PIN_SER_TENS_MIN);

      //diplay 4:00
      display_4(PIN_SCLK_ONES_HOUR,PIN_OUTCLK_ONES_HOUR,PIN_SER_ONES_HOUR); //ones place for the hour
      count_1hour(PIN_SCLK_ONES_MIN, PIN_OUTCLK_ONES_MIN, PIN_SER_ONES_MIN, PIN_SCLK_TENS_MIN, PIN_OUTCLK_TENS_MIN, PIN_SER_TENS_MIN);

      //diplay 5:00
      display_5(PIN_SCLK_ONES_HOUR,PIN_OUTCLK_ONES_HOUR,PIN_SER_ONES_HOUR); //ones place for the hour
      count_1hour(PIN_SCLK_ONES_MIN, PIN_OUTCLK_ONES_MIN, PIN_SER_ONES_MIN, PIN_SCLK_TENS_MIN, PIN_OUTCLK_TENS_MIN, PIN_SER_TENS_MIN);

      //diplay 6:00
      display_6(PIN_SCLK_ONES_HOUR,PIN_OUTCLK_ONES_HOUR,PIN_SER_ONES_HOUR); //ones place for the hour
      count_1hour(PIN_SCLK_ONES_MIN, PIN_OUTCLK_ONES_MIN, PIN_SER_ONES_MIN, PIN_SCLK_TENS_MIN, PIN_OUTCLK_TENS_MIN, PIN_SER_TENS_MIN);

      //diplay 7:00
      display_7(PIN_SCLK_ONES_HOUR,PIN_OUTCLK_ONES_HOUR,PIN_SER_ONES_HOUR); //ones place for the hour
      count_1hour(PIN_SCLK_ONES_MIN, PIN_OUTCLK_ONES_MIN, PIN_SER_ONES_MIN, PIN_SCLK_TENS_MIN, PIN_OUTCLK_TENS_MIN, PIN_SER_TENS_MIN);

      //diplay 8:00
      count_1hour(PIN_SCLK_ONES_MIN, PIN_OUTCLK_ONES_MIN, PIN_SER_ONES_MIN, PIN_SCLK_TENS_MIN, PIN_OUTCLK_TENS_MIN, PIN_SER_TENS_MIN);

      //diplay 9:00
      display_9(PIN_SCLK_ONES_HOUR,PIN_OUTCLK_ONES_HOUR,PIN_SER_ONES_HOUR); //ones place for the hour
      count_1hour(PIN_SCLK_ONES_MIN, PIN_OUTCLK_ONES_MIN, PIN_SER_ONES_MIN, PIN_SCLK_TENS_MIN, PIN_OUTCLK_TENS_MIN, PIN_SER_TENS_MIN);

      //diplay 10:00
      display_1(PIN_SCLK_TENS_HOUR, PIN_OUTCLK_TENS_HOUR, PIN_SER_TENS_HOUR); //tens place for the hour
      display_blank(PIN_SCLK_ONES_HOUR,PIN_OUTCLK_ONES_HOUR,PIN_SER_ONES_HOUR); //ones place for the hour
      count_1hour(PIN_SCLK_ONES_MIN, PIN_OUTCLK_ONES_MIN, PIN_SER_ONES_MIN, PIN_SCLK_TENS_MIN, PIN_OUTCLK_TENS_MIN, PIN_SER_TENS_MIN);

      //diplay 11:00
      display_1(PIN_SCLK_ONES_HOUR,PIN_OUTCLK_ONES_HOUR,PIN_SER_ONES_HOUR); //ones place for the hour
      count_1hour(PIN_SCLK_ONES_MIN, PIN_OUTCLK_ONES_MIN, PIN_SER_ONES_MIN, PIN_SCLK_TENS_MIN, PIN_OUTCLK_TENS_MIN, PIN_SER_TENS_MIN);

        //diplay 12:00
      display_2(PIN_SCLK_ONES_HOUR,PIN_OUTCLK_ONES_HOUR,PIN_SER_ONES_HOUR); //ones place for the hour
      count_1hour(PIN_SCLK_ONES_MIN, PIN_OUTCLK_ONES_MIN, PIN_SER_ONES_MIN, PIN_SCLK_TENS_MIN, PIN_OUTCLK_TENS_MIN, PIN_SER_TENS_MIN);
    }
  }
}

//------COUNT 1 HOUR---------------------------------------------------------------------------------------------------

void count_1hour(int SCLK_ONES_MIN, int OUTCLK_ONES_MIN, int SER_ONES_MIN, int SCLK_TENS_MIN, int OUTCLK_TENS_MIN, int SER_TENS_MIN)
{
  // #:00
  display_0(SCLK_TENS_MIN, OUTCLK_TENS_MIN, SER_TENS_MIN); //tens place for the min
  count_0_9(SCLK_ONES_MIN, OUTCLK_ONES_MIN, SER_ONES_MIN); //ones place for the min

  // #:10
  display_1(SCLK_TENS_MIN, OUTCLK_TENS_MIN, SER_TENS_MIN); //tens place for the min
  count_0_9(SCLK_ONES_MIN, OUTCLK_ONES_MIN, SER_ONES_MIN); //ones place for the min

  // #:20
  display_2(SCLK_TENS_MIN, OUTCLK_TENS_MIN, SER_TENS_MIN); //tens place for the min
  count_0_9(SCLK_ONES_MIN, OUTCLK_ONES_MIN, SER_ONES_MIN); //ones place for the min

  // #:30
  display_3(SCLK_TENS_MIN, OUTCLK_TENS_MIN, SER_TENS_MIN); //tens place for the min
  count_0_9(SCLK_ONES_MIN, OUTCLK_ONES_MIN, SER_ONES_MIN); //ones place for the min

  // #:40
  display_4(SCLK_TENS_MIN, OUTCLK_TENS_MIN, SER_TENS_MIN); //tens place for the min
  count_0_9(SCLK_ONES_MIN, OUTCLK_ONES_MIN, SER_ONES_MIN); //ones place for the min

  // #:50
  display_5(SCLK_TENS_MIN, OUTCLK_TENS_MIN, SER_TENS_MIN); //tens place for the min
  count_0_9(SCLK_ONES_MIN, OUTCLK_ONES_MIN, SER_ONES_MIN); //ones place for the min

  // #:60
  display_6(SCLK_TENS_MIN, OUTCLK_TENS_MIN, SER_TENS_MIN); //tens place for the min
  count_0_9(SCLK_ONES_MIN, OUTCLK_ONES_MIN, SER_ONES_MIN); //ones place for the min
}

//-----COUNT 0-9 ----------------------------------------------------------------------------------------------------

void count_0_9(int SCLK, int OUTCLK, int SER)
{
  display_0(SCLK, OUTCLK, SER);
  delay(1000);
  display_1(SCLK, OUTCLK, SER);
  delay(1000);
  display_2(SCLK, OUTCLK, SER);
  delay(1000);
  display_3(SCLK, OUTCLK, SER);
  delay(1000);
  display_4(SCLK, OUTCLK, SER);
  delay(1000);
  display_5(SCLK, OUTCLK, SER);
  delay(1000);
  display_6(SCLK, OUTCLK, SER);
  delay(1000);
  display_7(SCLK, OUTCLK, SER);
  delay(1000);
  display_8(SCLK, OUTCLK, SER);
  delay(1000);
  display_9(SCLK, OUTCLK, SER);
  delay(1000);
}

void display_blank(int SCLK, int OUTCLK, int SER)
{
  //ensure clocks are initially set low
  digitalWrite(OUTCLK, LOW); 
  digitalWrite(SCLK, LOW);

  //set segments G - A LOW
  for (int i = 0; i < 7; i++)
  {
    digitalWrite(SER, LOW);
    digitalWrite(SCLK, HIGH);
    digitalWrite(SCLK, LOW);
  }

  //send out the output
  digitalWrite(OUTCLK, HIGH);
}

//-----ZERO----------------------------------------------------------------------------------------------------

void display_0(int SCLK, int OUTCLK, int SER)
{
  //ensure clocks are initially set low
  digitalWrite(OUTCLK, LOW); 
  digitalWrite(SCLK, LOW);

  // G set LOW (i = 0)
  // A,B,C,D,E,F set HIGH (i = 1-6)
  for (int i = 0; i < 7; i++)
  {
    if (i == 0) 
    {
      digitalWrite(SER, LOW); //set G LOW
    }
    else 
    {
      digitalWrite(SER, HIGH);  // set the rest HIGH
    }
    digitalWrite(SCLK, HIGH);
    digitalWrite(SCLK, LOW);
  }

  //send out the output
  Serial.println("Display 0!");
  digitalWrite(OUTCLK, HIGH);
}

//-----ONE----------------------------------------------------------------------------------------------------

void display_1(int SCLK, int OUTCLK, int SER)
{
  //ensure clocks are initially set low
  digitalWrite(OUTCLK, LOW); 
  digitalWrite(SCLK, LOW);

  // G,F,E,D,A set LOW (i = 0 - 3, 6)
  //B and C set HIGH (i = 4,5)
  for (int i = 0; i < 7; i++)
  {
    if (i < 4 || i == 6) 
    {
      digitalWrite(SER, LOW); //set G,F,E,D,A LOW
    }
    else 
    {
      digitalWrite(SER, HIGH);  // set the rest HIGH
    }
    digitalWrite(SCLK, HIGH);
    digitalWrite(SCLK, LOW);
  }

  //send out the output
  Serial.println("Display 1!");
  digitalWrite(OUTCLK, HIGH);
}

